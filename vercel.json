{
  "buildCommand": "vite build && cp public/app.html dist/app.html",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/app.html",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/((?!app).*)", "destination": "/index.html" }
  ]
}