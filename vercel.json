{
  "buildCommand": "vite build && node copy-files.cjs",
  "outputDirectory": "dist",
  "headers": [
    { "source": "/app.html", "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }] },
    { "source": "/portal.html", "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }] },
    { "source": "/dealer-signup.html", "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }] },
    { "source": "/reset-password.html", "headers": [{ "key": "Content-Type", "value": "text/html; charset=utf-8" }] }
  ],
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/portal", "destination": "/portal.html" },
    { "source": "/dealer-signup", "destination": "/dealer-signup.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/((?!app|portal|dealer-signup|reset-password).*)", "destination": "/index.html" }
  ]
}